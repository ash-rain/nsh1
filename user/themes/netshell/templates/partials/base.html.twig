<!DOCTYPE html>
<html lang="{{ grav.language.getActive ?: 'en' }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if page.title %}{{ page.title }} | {% endif %}{{ site.title }}</title>
  <meta name="description" content="{{ page.summary|striptags ?: site.metadata.description }}">

  {# Fonts #}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

  {# Icons #}
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

  {# Theme CSS #}
  <link rel="stylesheet" href="{{ url('theme://css/theme.css') }}">

  {% block head %}{% endblock %}
</head>
<body>
  {# Background effects #}
  <div class="bg-grid"></div>
  <div class="bg-glow bg-glow--1"></div>
  <div class="bg-glow bg-glow--2"></div>

  {# Navigation #}
  {% include 'partials/nav.html.twig' %}

  {# Main Content #}
  <main>
    {% block content %}{% endblock %}
  </main>

  {# Footer #}
  {% include 'partials/footer.html.twig' %}

  {# JS #}
  <script src="{{ url('theme://js/theme.js') }}"></script>
  {% block scripts %}{% endblock %}
</body>
</html>
