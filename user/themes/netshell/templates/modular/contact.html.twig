<section class="section" id="contact">
  <div class="container">
    {# CTA Banner #}
    <div class="cta-banner reveal" style="margin-bottom: 80px;">
      <h2 class="cta-banner__title">{{ 'THEME.CTA.TITLE'|t }}</h2>
      <p class="cta-banner__desc">{{ 'THEME.CTA.DESC'|t }}</p>
      <a href="https://calendly.com/netshell/30min" target="_blank" class="btn btn--primary">
        <i class="fas fa-calendar"></i> {{ 'THEME.CTA.BUTTON'|t }}
      </a>
    </div>

    <div class="section__header reveal">
      <span class="section__label"><i class="fas fa-envelope"></i> {{ 'THEME.CONTACT.LABEL'|t }}</span>
      <h2 class="section__title">{{ page.header.title|default('THEME.CONTACT.TITLE'|t) }}</h2>
    </div>

    <div class="contact-grid reveal">
      <div class="contact__info">
        {{ page.content|raw }}

        <div class="contact__item">
          <div class="contact__icon"><i class="fas fa-envelope"></i></div>
          <div>
            <div class="contact__label">Email</div>
            <div class="contact__value">
              <a href="mailto:hi@nsh.one">hi@nsh.one</a>
            </div>
          </div>
        </div>

        <div class="contact__item">
          <div class="contact__icon"><i class="fab fa-telegram"></i></div>
          <div>
            <div class="contact__label">Telegram</div>
            <div class="contact__value">
              <a href="https://t.me/nsh963" target="_blank">@nsh963</a>
            </div>
          </div>
        </div>

        <div class="contact__item">
          <div class="contact__icon"><i class="fas fa-map-marker-alt"></i></div>
          <div>
            <div class="contact__label">{{ 'THEME.CONTACT.LOCATION'|t }}</div>
            <div class="contact__value">{{ 'THEME.CONTACT.CITY'|t }}</div>
          </div>
        </div>

        <div class="contact__social">
          <a href="https://github.com/net-shell" target="_blank" class="contact__social-link" title="GitHub">
            <i class="fab fa-github"></i>
          </a>
          <a href="https://github.com/ash-rain" target="_blank" class="contact__social-link" title="GitHub (Personal)">
            <i class="fab fa-github"></i>
          </a>
          <a href="https://linkedin.com/company/netshell" target="_blank" class="contact__social-link" title="LinkedIn">
            <i class="fab fa-linkedin-in"></i>
          </a>
          <a href="https://facebook.com/nsh.0001" target="_blank" class="contact__social-link" title="Facebook">
            <i class="fab fa-facebook-f"></i>
          </a>
          <a href="https://t.me/nsh963" target="_blank" class="contact__social-link" title="Telegram">
            <i class="fab fa-telegram-plane"></i>
          </a>
        </div>
      </div>

      <div class="contact__form">
        <h3 style="margin-bottom: 24px; font-size: 1.2rem;">{{ 'THEME.CONTACT.FORM_TITLE'|t }}</h3>
        {% set contact_form = grav.forms.get('contact') %}
        {% if contact_form and contact_form.messages %}
          {% for msg in contact_form.messages %}
            <div class="form__message form__message--{{ msg.type ?? 'info' }}" style="margin-bottom:16px; padding:12px 16px; border-radius:8px; background: {% if msg.type == 'error' %}rgba(239,68,68,.15){% else %}rgba(99,102,241,.15){% endif %}; color: {% if msg.type == 'error' %}#f87171{% else %}#a5b4fc{% endif %};">
              {{ msg|raw }}
            </div>
          {% endfor %}
        {% endif %}
        <form id="contact" name="contact" method="post" action="{{ page.parent.url }}">
          <input type="hidden" name="__form-name__" value="contact">
          {{ nonce_field('form', 'form-nonce')|raw }}
          <div class="form__group">
            <label class="form__label">{{ 'THEME.CONTACT.NAME'|t }}</label>
            <input type="text" name="name" class="form__input" required>
          </div>
          <div class="form__group">
            <label class="form__label">Email</label>
            <input type="email" name="email" class="form__input" required>
          </div>
          <div class="form__group">
            <label class="form__label">{{ 'THEME.CONTACT.MESSAGE'|t }}</label>
            <textarea name="message" class="form__textarea" required></textarea>
          </div>
          <button type="submit" class="btn btn--primary" style="width: 100%; justify-content: center;">
            <i class="fas fa-paper-plane"></i> {{ 'THEME.CONTACT.SEND'|t }}
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
